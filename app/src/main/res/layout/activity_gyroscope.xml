<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="传感器数据"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="40dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="线性加速度"
                    android:textColor="#00FFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvLinearX"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="X: 0.00"
                    android:textColor="#00FF00"
                    android:textSize="16sp"
                    android:layout_marginBottom="5dp" />

                <TextView
                    android:id="@+id/tvLinearY"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Y: 0.00"
                    android:textColor="#00FF00"
                    android:textSize="16sp"
                    android:layout_marginBottom="5dp" />

                <TextView
                    android:id="@+id/tvLinearZ"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Z: 0.00"
                    android:textColor="#00FF00"
                    android:textSize="16sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="方向"
                    android:textColor="#00FFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvOrientAzimuth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Azimuth (方位角): 0.00"
                    android:textColor="#00FF00"
                    android:textSize="16sp"
                    android:layout_marginBottom="5dp" />

                <TextView
                    android:id="@+id/tvOrientPitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pitch (俯仰角): 0.00"
                    android:textColor="#00FF00"
                    android:textSize="16sp"
                    android:layout_marginBottom="5dp" />

                <TextView
                    android:id="@+id/tvOrientRoll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Roll (翻滚角): 0.00"
                    android:textColor="#00FF00"
                    android:textSize="16sp" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="基准值"
            android:textColor="#FFFF00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tvBaseRoll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Roll基准值: 0.00"
            android:textColor="#FFFF00"
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:background="#444444"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="10dp"
                android:layout_marginEnd="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="检测结果（算法1）"
                    android:textColor="#FF00FF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvDetectionResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="计算中"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:background="#444444"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="检测结果（算法2）"
                    android:textColor="#00FF00"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvDetectionResult2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="计算中"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="#444444"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="最终结果"
                android:textColor="#FFA500"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvFinalResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="计算中"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开始"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:layout_marginEnd="10dp"
                android:minWidth="100dp" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="停止"
                android:textColor="#FFFFFF"
                android:backgroundTint="#F44336"
                android:minWidth="100dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnSimulateCall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="来电模拟"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2196F3"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:minWidth="150dp" />

    </LinearLayout>

</ScrollView>
